# Everything below is fetched / generated by setup.ps1 / setup.sh.
# Only the glue (scripts, demo page, custom assets, docs) is tracked in git.

/tinymce/
/fileimagemanager/
/.bundle-version.json

# Thumbnail cache — regenerated by the File & Image Manager on demand.
/media/thumbs/*
!/media/thumbs/.gitkeep

# OS / editor noise
Thumbs.db
.DS_Store
*.tmp
