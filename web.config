<?xml version="1.0" encoding="UTF-8"?>
<!--
  IIS configuration for the demo / landing page at the bundle root.
  The File & Image Manager ships its own web.config under fileimagemanager/public/
  (front-controller rewrite + security headers) which applies inside that folder.
-->
<configuration>
  <system.webServer>
    <defaultDocument>
      <files>
        <clear />
        <add value="index.php" />
        <add value="index.html" />
      </files>
    </defaultDocument>

    <directoryBrowse enabled="false" />

    <!-- MIME types the manager / TinyMCE rely on (guarded so they don't clash with server defaults). -->
    <staticContent>
      <remove fileExtension=".webp" /><mimeMap fileExtension=".webp" mimeType="image/webp" />
      <remove fileExtension=".avif" /><mimeMap fileExtension=".avif" mimeType="image/avif" />
      <remove fileExtension=".woff2" /><mimeMap fileExtension=".woff2" mimeType="font/woff2" />
      <remove fileExtension=".json" /><mimeMap fileExtension=".json" mimeType="application/json" />
      <remove fileExtension=".mjs" /><mimeMap fileExtension=".mjs" mimeType="text/javascript" />
      <remove fileExtension=".md" /><mimeMap fileExtension=".md" mimeType="text/markdown; charset=utf-8" />
    </staticContent>
  </system.webServer>
</configuration>
